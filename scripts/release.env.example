# AUTO-RELEASE SCRIPT FOR YOUR NEXTCLOUD INSTANCE
# Copy to scripts/release.env and fill in. release.env is gitignored.
#
# Use a Nextcloud *app password* (Settings > Security > Devices & sessions),
# not your account password.

NC_BASE_URL="https://your-nexcloud-url.com"
NC_USER="your-nextcloud-user"
NC_PASS="your-nextcloud-app-password"

# Remote folder (under the user's files) where APKs + manifest live.
NC_DIR="krab"

# Remote path of the manifest the app reads (must match MANIFEST_URL's file).
NC_MANIFEST_PATH="krab/manifest.json"

# Optional: keep at most this many releases in the manifest (mandatory ones are
# always kept regardless). Leave empty to never prune.
MAX_RELEASES=""
