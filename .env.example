# DB configuration variables
SUPABASE_URL='https://your_supabase_url_here.example.com'
SUPABASE_ANON_KEY='your_anon_key_here'

# Auto-update configuration variables
MANIFEST_URL='YOUR_MANIFEST_URL'
ENABLE_AUTO_UPDATE='false'

# Password reset configuration variables
ENABLE_PASSWORD_RESET='true'
PASSWORD_RESET_URL='https://your-domain.com/reset-password.html'

# Email verification: where the confirmation link lands after verifying.
# Leave unset if email verification isn't enabled.
EMAIL_CONFIRM_URL='https://your-domain.com/confirmed.html'